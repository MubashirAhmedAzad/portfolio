# ──────────────────────────────────────────────────────────────────────────────
# n8n environment variables for Google Cloud Run + Supabase
#
# Copy this file to .env (never commit .env to version control) and fill in
# every value marked as REQUIRED before deploying.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# REQUIRED – find these values in Supabase > Project Settings > Database
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=db.<your-supabase-project-ref>.supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=<your-supabase-db-password>
# Enable SSL for Supabase (strongly recommended)
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=true

# ── n8n host / networking ─────────────────────────────────────────────────────
# REQUIRED – replace with your Cloud Run service URL after the first deployment,
# or a custom domain if you set one up.
N8N_HOST=<your-cloud-run-url>          # e.g. https://n8n-abc123-uc.a.run.app
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=<your-cloud-run-url>        # must match N8N_HOST

# ── Basic authentication ───────────────────────────────────────────────────────
# REQUIRED – protects the n8n UI with a username / password
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=<your-n8n-username>
N8N_BASIC_AUTH_PASSWORD=<your-n8n-password>

# ── Encryption key ────────────────────────────────────────────────────────────
# REQUIRED – used to encrypt credentials stored in the database.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=<generate-a-random-32-byte-hex-string>

# ── Execution / storage settings ─────────────────────────────────────────────
# Keep executions in the database (works well with Supabase)
EXECUTIONS_PROCESS=main
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_MAX_AGE=168          # hours (7 days)

# ── Optional: timezone ────────────────────────────────────────────────────────
GENERIC_TIMEZONE=UTC

# ── Optional: log level ───────────────────────────────────────────────────────
N8N_LOG_LEVEL=info
